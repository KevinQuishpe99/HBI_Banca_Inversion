# El demo HBI funciona SIN .env (auth y datos quemados en código).
# Copia a .env.local solo si conectas PostgreSQL, Azure o login Microsoft.

# PostgreSQL (opcional — producción con BD)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=hbi_agente_financiacion_db
# DB_USER=postgres
# DB_PASSWORD=
# DB_SSL=false

# Azure Blob (opcional)
# AZURE_STORAGE_ACCOUNT=
# AZURE_STORAGE_KEY=
# AZURE_CONTAINER_NAME=hbi-expedientes

# NextAuth (opcional — en Vercel usa VERCEL_URL automáticamente)
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=

# Microsoft login (opcional — desactivado por defecto sin configurar)
# AZURE_AUTH_TENANT_ID=
# AZURE_AUTH_CLIENT_ID=
# AZURE_AUTH_CLIENT_SECRET=
# MICROSOFT_LOGIN_ALLOWED_DOMAINS=

# Microsoft Graph / correos (opcional)
# AZURE_MAIL_TENANT_ID=
# AZURE_MAIL_CLIENT_ID=
# AZURE_MAIL_CLIENT_SECRET=
# MAIL_FROM_ADDRESS=
