# Copiar a .env.local y completar (no commitear secretos reales)

# HBI: datos quemados + auth demo (sin PostgreSQL). Poner false cuando la BD esté lista.
NEXT_PUBLIC_HBI_MOCK_DATA=true

# En demo no son obligatorias. Solo si deseas forzar URL/secret manual:
# NEXTAUTH_URL=https://tu-proyecto.vercel.app
# NEXTAUTH_SECRET=opcional-en-demo

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hbi_agente_financiacion_db
DB_USER=postgres
DB_PASSWORD=
DB_SSL=false
DB_POOL_MAX=2
DB_CONNECTION_TIMEOUT_MS=30000

# Azure Blob (documentos contractuales)
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_CONTAINER_NAME=hbi-expedientes

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generar-con-openssl-rand-base64-32
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000

# Microsoft login (opcional)
AZURE_AUTH_TENANT_ID=
AZURE_AUTH_CLIENT_ID=
AZURE_AUTH_CLIENT_SECRET=
NEXT_PUBLIC_MICROSOFT_LOGIN_ENABLED=false
MICROSOFT_LOGIN_ALLOWED_DOMAINS=

# Microsoft Graph (correos operación — Fase 2, pendiente integración)
AZURE_MAIL_TENANT_ID=
AZURE_MAIL_CLIENT_ID=
AZURE_MAIL_CLIENT_SECRET=
MAIL_FROM_ADDRESS=

# Límites API
RATE_LIMIT_AUTH_MAX=45
RATE_LIMIT_API_MAX=200
RATE_LIMIT_WINDOW_MS=60000
